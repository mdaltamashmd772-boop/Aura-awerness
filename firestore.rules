rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isVerified() {
      return request.auth.token.email_verified == true;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['name']) 
        && data.name is string && data.name.size() <= 100
        && (!data.keys().hasAny(['selectedIcon']) || data.selectedIcon is string)
        && (!data.keys().hasAny(['lastSeedDate']) || data.lastSeedDate is string)
        && (!data.keys().hasAny(['notificationEnabled']) || data.notificationEnabled is bool)
        && (!data.keys().hasAny(['notificationTime']) || data.notificationTime is string);
    }

    function isValidLog(data) {
      return data.keys().hasAll(['date', 'mood', 'energy'])
        && data.date is string && data.date.size() <= 20
        && data.mood is int && data.mood >= 1 && data.mood <= 5
        && data.energy is int && data.energy >= 1 && data.energy <= 5
        && (!data.keys().hasAny(['gratitude']) || (data.gratitude is list && data.gratitude.size() <= 10))
        && (!data.keys().hasAny(['seedCompleted']) || data.seedCompleted is bool)
        && (!data.keys().hasAny(['sleepHours']) || data.sleepHours is number)
        && (!data.keys().hasAny(['affirmation']) || data.affirmation is string)
        && (!data.keys().hasAny(['aiReflection']) || data.aiReflection is string);
    }

    match /users/{userId} {
      allow get: if isUser(userId);
      allow create: if isUser(userId) && isValidId(userId) && isValidUser(incoming());
      allow update: if isUser(userId) && isValidUser(incoming()) && isVerified()
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'selectedIcon', 'lastSeedDate', 'notificationEnabled', 'notificationTime'])
        );

      match /logs/{date} {
        allow list, get: if isUser(userId);
        allow create: if isUser(userId) && isValidId(date) && isValidLog(incoming());
        allow update: if isUser(userId) && isValidLog(incoming()) && isVerified()
          && (
            incoming().diff(existing()).affectedKeys().hasOnly(['mood', 'energy', 'gratitude', 'seedCompleted', 'sleepHours', 'affirmation', 'aiReflection'])
          );
        allow delete: if isUser(userId);
      }
    }
  }
}
